From f092f7b7dae3650112d6ac9a2e25d08957035b71 Mon Sep 17 00:00:00 2001
From: Bernd Kuhls <bernd@kuhls.net>
Date: Fri, 23 Jun 2023 22:44:17 +0200
Subject: [PATCH] Revert "ash: only allow local variables in functions"

This reverts commit ef2386b80abfb22ccb697ddbdd4047aacc395c50.

Signed-off-by: Bernd Kuhls <bernd@kuhls.net>
---
 shell/ash.c                          | 3 ---
 shell/ash_test/ash-misc/local2.right | 1 -
 shell/ash_test/ash-misc/local2.tests | 1 -
 3 files changed, 5 deletions(-)
 delete mode 100644 shell/ash_test/ash-misc/local2.right
 delete mode 100755 shell/ash_test/ash-misc/local2.tests

diff --git a/shell/ash.c b/shell/ash.c
index 5f8c8ea19..59be10d9d 100644
--- a/shell/ash.c
+++ b/shell/ash.c
@@ -10036,9 +10036,6 @@ localcmd(int argc UNUSED_PARAM, char **argv)
 {
 	char *name;
 
-	if (!localvar_stack)
-		ash_msg_and_raise_error("not in a function");
-
 	argv = argptr;
 	while ((name = *argv++) != NULL) {
 		mklocal(name, 0);
diff --git a/shell/ash_test/ash-misc/local2.right b/shell/ash_test/ash-misc/local2.right
deleted file mode 100644
index 630ef7979..000000000
--- a/shell/ash_test/ash-misc/local2.right
+++ /dev/null
@@ -1 +0,0 @@
-./local2.tests: local: line 1: not in a function
diff --git a/shell/ash_test/ash-misc/local2.tests b/shell/ash_test/ash-misc/local2.tests
deleted file mode 100755
index 8e14037c5..000000000
--- a/shell/ash_test/ash-misc/local2.tests
+++ /dev/null
@@ -1 +0,0 @@
-local x=1
-- 
2.39.2

